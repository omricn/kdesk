# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Demo mode ─────────────────────────────────────────────────────────────────
# True  → visit /demo-login/ to log in automatically (no Azure needed)
# False → normal Azure SSO flow (requires Azure App Registration)
DEMO_MODE=True

# ── Database (Docker Compose spins this up automatically) ─────────────────────
DB_NAME=kdesk
DB_USER=kdesk
DB_PASSWORD=kdesk
DB_HOST=db
DB_PORT=5432

# ── Redis / Celery (Docker Compose spins this up automatically) ───────────────
REDIS_URL=redis://redis:6379/0

# ── AI features (optional) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Azure (only needed when DEMO_MODE=False) ──────────────────────────────────
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_REDIRECT_URI=http://localhost:8000/auth/callback/
