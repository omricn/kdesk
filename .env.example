# ── Django ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=kdesk
DB_USER=kdesk
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Microsoft Graph API ──────────────────────────────────────────────────────
# Create an App Registration in Entra ID (Azure Portal) and fill these in.
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── Mailbox ──────────────────────────────────────────────────────────────────
SERVICEDESK_EMAIL=servicedesk@kramerav.com

# ── Entra User Sync ──────────────────────────────────────────────────────────
ENTRA_USER_GROUP=KramerLicensedUsers

# ── Email Polling ─────────────────────────────────────────────────────────────
# How often (in minutes) to check the mailbox for new tickets
EMAIL_POLL_INTERVAL=5

# ── SSO ───────────────────────────────────────────────────────────────────────
# Must match exactly what you register in the Azure App Registration redirect URIs.
# Local dev:   http://localhost:8000/auth/callback/
# Production:  http://your-server-ip:8000/auth/callback/
AZURE_REDIRECT_URI=http://localhost:8000/auth/callback/

# Mail-enabled security group — only members can log in to Kdesk
IT_GROUP_EMAIL=IL_OPS_IT@kramerav.com

# ── Groq AI ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
